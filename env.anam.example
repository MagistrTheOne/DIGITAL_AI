# Скопируйте блок в `.env.local`. Файлы `.env*` в репозитории не коммитятся.
# Документация: documents/anam-avatar-pipeline.md

# Обязательно: секретный ключ из Lab → «API keys» (не UUID окружения / Environment id)
ANAM_API_KEY=

# Готовая персона Lab (приоритет над inline avatar/voice/llm для /api/anam/session)
ANAM_PERSONA_ID=deac7256-b641-40e0-9939-5da33a5f5817

# Inline persona (если ANAM_PERSONA_ID не задан — тогда нужны все три)
ANAM_AVATAR_ID=2e5bacac-6888-4c76-bcf5-266fd42b9444
ANAM_VOICE_ID=de23e340-1416-4dd8-977d-065a7ca11697
ANAM_LLM_ID=85906141-db1c-4927-b74d-3c82ebe2436e

# Environment id из Lab (отдельно от API key)
ANAM_ENVIRONMENT_ID=41648ba8-b8b9-4e8f-a79c-982c6234fef7
# Отправлять environmentId в теле session-token (при 400 от API — закомментировать)
ANAM_SESSION_SEND_ENVIRONMENT=1
